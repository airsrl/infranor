<odoo>
    <record id="infranor_view_partner_form_inherit" model="ir.ui.view">
        <field name="name">infranor_view_partner_form_inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']//field[@name='company_id']" position="attributes">
                <attribute name="groups"/>
            </xpath>

            <page name="internal_notes" position="before">
                <page name="budget" string="Budget cliente" attrs="{'invisible': [('parent_id', '!=', False)]}">
                    <field name="budget_ids">
                        <tree editable="bottom">
                            <field name="currency_id" invisible="1"/>
                            <field name="year"/>
                            <field name="sales_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="invoiced_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="budget_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            <field name="region_id" options="{'no_open': True}" optional="hide"/>
                            <field name="sale_person_id" optional="hide"/>
                            <field name="budget_progress" optional="show" widget="progressbar" nolabel="1"/>
                            <field name="remaining_budget" optional="hide" decoration-success="remaining_budget &lt;= 0"/>
                        </tree>
                    </field>
                </page>
            </page>
        </field>
    </record>

    <record id="infranor_view_partner_form_delivery_note_inherit" model="ir.ui.view">
        <field name="name">infranor_view_partner_form_delivery_note_inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="l10n_it_delivery_note.res_partner_form_view"/>
        <field name="arch" type="xml">
            <field name="default_goods_appearance_id" position="before">
                <field name="carrier_id"/>
            </field>
        </field>
    </record>
</odoo>