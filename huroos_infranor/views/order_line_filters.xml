<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="filter_righe_ordini_vendite_aperte" model="ir.filters">
        <field name="name">Righe ordini aperti</field>
        <field name="model_id">sale.order.line</field>
        <field name="domain">[("invoice_status", "!=", "invoiced"), ("state", "=", "sale"),('qty_to_deliver','>',0)]</field>
        <field name="user_id" eval="False"/>
        <field name="context">{}</field>
    </record>
        <record id="filter_righe_ordini_acquisto_aperte" model="ir.filters">
        <field name="name">Righe ordini aperti</field>
        <field name="model_id">purchase.order.line</field>
        <field name="domain">[('qty_to_deliver','>',0)]</field>
        <field name="user_id" eval="False"/>
        <field name="context">{}</field>
    </record>
    </data>
</odoo>