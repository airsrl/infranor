<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="product_product_form_inherit" model="ir.ui.view">
            <field name="name">product_product_form_inherit</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="stock.product_product_stock_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='free_qty']" position="before">
                    <field name="position" class="oe_inline"/>
                    <button name="%(action_edit_posizione)d" title="Modifica Posizione" type="action"  class="oe_inline btn-link"
                            icon="fa-pencil"
                            context="{'default_product_id': id, 'default_product_id': id, 'default_new_position': position}"
                    />
                </xpath>
            </field>
        </record>

              <record id="product_template_form_inherit" model="ir.ui.view">
            <field name="name">product_template_form_inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='detailed_type']" position="after">
                    <field name="position" class="oe_inline"/>
                </xpath>
            </field>
        </record>



    </data>
</odoo>