<odoo>
    <record id="view_res_partner_budget_tree" model="ir.ui.view">
        <field name="name">view_res_partner_budget_tree</field>
        <field name="model">res.partner.budget</field>
        <field name="arch" type="xml">
            <tree editable="bottom" expand="1">
                <field name="partner_id" decoration-bf="1"/>
                <field name="year"/>
                <field name="sales_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
            </tree>
        </field>
    </record>

    <record id="view_res_partner_budget_search" model="ir.ui.view">
        <field name="name">view_res_partner_budget_search</field>
        <field name="model">res.partner.budget</field>
        <field name="arch" type="xml">
            <search>
                <filter string="Cliente" name="group_by_partner" context="{'group_by': 'partner_id'}"/>
                <filter string="Anno" name="group_by_year" context="{'group_by': 'year'}"/>
            </search>
        </field>
    </record>

    <record id="action_res_partner_budget" model="ir.actions.act_window">
        <field name="name">Budget clienti</field>
        <field name="res_model">res.partner.budget</field>
        <field name="context">{'search_default_group_by_partner': 1}</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_res_partner_budget" name="Budget clienti" parent="sale.menu_sale_config"
              action="action_res_partner_budget"/>
</odoo>