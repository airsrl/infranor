<odoo>

    <record id="infranor_view_sale_order_pivot_inherit" model="ir.ui.view">
        <field name="name">infranor_view_sale_order_pivot_inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sale_order_pivot"/>
        <field name="arch" type="xml">
            <pivot position="inside">
                <field name="partner_id" type="row"/>
                <field name="current_year_budget" type="measure"/>
            </pivot>

            <field name="date_order" position="attributes">
                <attribute name="type"/>
            </field>
        </field>
    </record>

    <record id="sale_order_line_tree_inherit_infranor" model="ir.ui.view">
        <field name="name">sale.order.line.tree.inherit.infranor</field>
        <field name="model">sale.order.line</field>
        <field name="inherit_id" ref="sale.view_order_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='salesman_id']" position="after">
                <field name="x_studio_date_prevue" optional="show"/>
                <field name="commitment_date" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>