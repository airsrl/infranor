<odoo>
    <template id="infranor_report_saleorder_document" inherit_id="sale.report_saleorder_document">
        <xpath expr="//div[hasclass('page')]//h2[hasclass('mt-4')]" position="replace">
            <h2 class="mt-4">
                <t t-if="env.company.id != 8">
                    <span t-if="env.context.get('proforma', False) or is_pro_forma">Pro-Forma Invoice #</span>
                    <span t-elif="doc.state in ['draft','sent']">Quotation #</span>
                    <span t-else="">Order #</span>
                    <span t-field="doc.name"/>
                </t>
                <t t-else="">
                    <span t-if="env.context.get('proforma', False) or is_pro_forma">Fattura Pro-forma n. </span>
                    <span t-elif="doc.state in ['draft','sent']">Offerta n. </span>
                    <span t-else="">Conferma d'ordine n. </span>
                    <span t-if="doc.state in ['draft','sent']" t-field="doc.offer_number"/>
                    <span t-else="" t-field="doc.name"/>
                </t>
            </h2>
        </xpath>
    </template>

    <!--Template che eredita un template NON presente sul codice ma SOLO sul db del cliente Infranor Srl (Realizzato con Odoo Studio :|)-->
    <template id="report_sale_order_odoo_studio_inherit" inherit_id="studio_customization.odoo_studio_report_s_c34ee198-06e3-4208-8fb0-729e5a0b64a1">
        <!--Replace colonne CODICE SA e ORIGINE (solo per company Infranor srl)-->
        <xpath expr="/t/t/div/table/thead/tr/th[5]" position="attributes">
            <attribute name="t-if">env.company.id != 8</attribute>
        </xpath>
        <xpath expr="/t/t/div/table/thead/tr/th[6]" position="attributes">
            <attribute name="t-if">env.company.id != 8</attribute>
        </xpath>
        <xpath expr="/t/t/div/table/tbody/t[2]/tr/t[1]/td[5]" position="attributes">
            <attribute name="t-if">env.company.id != 8</attribute>
        </xpath>
        <xpath expr="/t/t/div/table/tbody/t[2]/tr/t[1]/td[6]" position="attributes">
            <attribute name="t-if">env.company.id != 8</attribute>
        </xpath>

        <!--Colonna prezzo unitario-->
        <th name="th_priceunit" position="replace">
            <th name="th_priceunit" class="text-end">
                <t t-if="env.company.id != 8">Prix unitaire</t>
                <t t-else="">PREZZO UNITARIO</t>
            </th>
        </th>

        <!--Colonna expected date-->
        <xpath expr="/t/t/div/table/thead/tr/th[4]" position="replace">
            <th>
                <t t-if="env.company.id != 8">Expected date</t>
                <t t-else="">CONSEGNA</t>
            </th>
        </xpath>

        <!--Data ordine-->
        <xpath expr="/t/t/div/div[2]/div[1]/span" position="attributes">
            <attribute name="t-if">env.company.id != 8</attribute>
        </xpath>
        <xpath expr="/t/t/div/div[2]/div[1]/span" position="after">
            <strong t-if="env.company.id == 8">Data: </strong>
        </xpath>

        <!--Addetto vendite-->
        <xpath expr="/t/t/div/div[2]/div[2]/span" position="attributes">
            <attribute name="t-if">env.company.id != 8</attribute>
        </xpath>
        <xpath expr="/t/t/div/div[2]/div[2]/span" position="after">
            <strong t-if="env.company.id == 8">Ns. Riferimento: </strong>
            <br/>
        </xpath>

        <!--Rif. cliente-->
        <xpath expr="/t/t/div/div[2]/div[3]/span[1]/strong" position="attributes">
            <attribute name="t-if">env.company.id != 8</attribute>
        </xpath>
        <xpath expr="/t/t/div/div[2]/div[3]/span[1]/strong" position="after">
            <strong t-if="env.company.id == 8">Vs. Riferimento: </strong>
        </xpath>

        <!--Termini di pagamento-->
        <xpath expr="/t/t/div/div[4]" position="replace">
            <div t-if="env.company.id != 8" class="row">
                <div class="col">
                    <span t-field="doc.payment_term_id.note"/>
                </div>
            </div>
            <h4 style="font-weight: bold;margin-top: 30px;">
                <div style="margin-bottom: -20px;"><span t-field="doc.payment_term_id.note"/></div>
                <t t-if="doc.incoterm"><span t-esc="doc.incoterm.name.lower().capitalize()"/><br/></t>
                Imballo: Compreso<br/>
                <t t-if="doc.state in ['draft','sent']">Validità dell'offerta: 30 giorni</t>
            </h4>
        </xpath>

        <!--Termini e condizioni su pagina a parte-->
        <xpath expr="/t/t/div/div[6]" position="before">
            <t t-if="env.company.id == 8"><p style="page-break-after:always;"/></t>
        </xpath>
    </template>
</odoo>